package com.blog.afaq.controller;

import com.blog.afaq.dto.response.*;
import com.blog.afaq.service.*;
        import lombok.RequiredArgsConstructor;
import org.springframework.web.bind.annotation.*;

import java.time.Instant;
import java.time.temporal.ChronoUnit;
import java.util.List;
import java.util.Map;

@RestController
@RequestMapping("/api/analytics")
@RequiredArgsConstructor
public class AnalyticsController {

    private final AnalyticsService analyticsService;
    private final ArticleService articleService;
    private final InitiativeService initiativeService;
    private final RessourceService ressourceService;
    private final CommentService commentService;


    @GetMapping("/count-articles")
    public long getTotalArticles() {
        return articleService.getTotalArticles();
    }

    @GetMapping("/count-initiatives")
    public long getTotalInitiaves() {
        return initiativeService.getTotalInitiatives();
    }
    @GetMapping("/count-ressources")
    public long getTotalResources() {
        return ressourceService.getTotalResources();
    }
    @PostMapping("/event")
    public void trackEvent(
            @RequestBody AnalyticsRequest request,
            @RequestHeader(value = "X-Visitor-Id", required = false) String visitorId,
            @RequestHeader(value = "X-Session-Id", required = false) String sessionId
    ) {
        analyticsService.trackEvent(request, visitorId, sessionId);
    }
    @GetMapping("/stats")
    public Map<String, Long> getCommentStatistics() {
        return commentService.getCommentStats();
    }
    @GetMapping("/users/non-admin")
    public List<UserDto> getNonAdminUsers() {
        return analyticsService.getAllNonAdminUsers();
    }


    @GetMapping("/dashboard")
    public AnalyticsDashboardDto dashboard() {
        return analyticsService.getDashboard();
    }

    @GetMapping("/traffic/daily")
    public List<TrafficPerDayDto> traffic(@RequestParam int days) {
        Instant since = Instant.now().minus(days, ChronoUnit.DAYS);
        return analyticsService.getTrafficPerDay(since);
    }

    @GetMapping("/top-pages")
    public List<TopPageDto> topPages(@RequestParam(defaultValue = "10") int limit) {
        return analyticsService.getTopPages(limit);
    }

    @GetMapping("/top-articles")
    public List<TopArticleDto> topArticles() {
        return analyticsService.getTopArticles();
    }

    @GetMapping("/device-stats")
    public List<UserAgentStatsDto> getUserAgents() {
        return analyticsService.getUserAgentStats();
    }
}
