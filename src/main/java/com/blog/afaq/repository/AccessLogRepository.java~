package com.blog.afaq.repository;

import com.blog.afaq.dto.response.*;
import com.blog.afaq.model.AccessLog;
import org.springframework.data.mongodb.repository.Aggregation;
import org.springframework.data.mongodb.repository.MongoRepository;

import java.time.Instant;
import java.util.List;

public interface AccessLogRepository extends MongoRepository<AccessLog, String>, CustomAccessLogRepository {
    @Aggregation(pipeline = {
            "{ $group: { _id: { $ifNull: ['$visitorId', '$userEmail'] } } }",
            "{ $count: 'uniqueVisitors' }"
    })
    Long countUniqueVisitors();
    @Aggregation(pipeline = {
            "{ $match: { accessTime: { $gte: ?0, $lte: ?1 } } }",
            "{ $group: { _id: { $ifNull: ['$visitorId', '$userEmail'] } } }",
            "{ $count: 'uniqueVisitors' }"
    })
    Long countUniqueVisitorsBetween(Instant start, Instant end);

    @Aggregation(pipeline = {
            "{ $match: { event: 'PAGE_VIEW' } }",
            "{ $group: { _id: '$path', views: { $sum: 1 } } }",
            "{ $sort: { views: -1 } }",
            "{ $limit: ?0 }",
            "{ $project: { path: '$_id', views: 1, _id: 0 } }"
    })
    List<TopPageDto> getTopPages(int limit);

    @Aggregation(pipeline = {
            "{ $match: { event: 'PAGE_VIEW', category: 'ARTICLE', pageId: { $ne: null } } }",

            "{ $group: { _id: '$pageId', views: { $sum: 1 } } }",

            "{ $lookup: { " +
                    "from: 'articles', " +
                    "let: { articleId: { $toObjectId: '$_id' } }, " +
                    "pipeline: [ " +
                    "{ $match: { $expr: { $eq: ['$_id', '$$articleId'] } } } " +
                    "], " +
                    "as: 'article' " +
                    "} }",

            "{ $unwind: '$article' }",

            "{ $project: { " +
                    "title: '$article.title', " +
                    "views: 1, " +
                    "_id: 0 " +
                    "} }",

            "{ $sort: { views: -1 } }",

            "{ $limit: 10 }"
    })
    List<TopArticleDto> getTopArticles();

    @Aggregation(pipeline = {
            "{ $match: { accessTime: { $gte: ?0 } } }",
            "{ $group: { _id: '$sessionId' } }",
            "{ $count: 'activeSessions' }"
    })
    Long countActiveSessions(Instant since);

    @Aggregation(pipeline = {
            "{ $match: { accessTime: { $gte: ?0 } } }",
            "{ $group: { _id: { $dateToString: { format: '%Y-%m-%d', date: '$accessTime' } }, count: { $sum: 1 } } }",
            "{ $project: { date: '$_id', count: 1, _id: 0 } }",
            "{ $sort: { date: 1 } }"
    })
    List<TrafficPerDayDto> getTrafficPerDay(Instant since);

    @Aggregation(pipeline = {
            "{ $match: { deviceType: { $ne: null } } }",
            "{ $group: { _id: '$deviceType', count: { $sum: 1 } } }",
            "{ $project: { type: '$_id', count: 1, _id: 0 } }",
            "{ $sort: { count: -1 } }"
    })
    List<UserAgentStatsDto> getUserAgentStats();


    @Aggregation(pipeline = {
            "{ $match: { event: 'PAGE_VIEW', category: 'PROJECT', pageId: { $ne: null } } }",

            "{ $group: { _id: '$pageId', views: { $sum: 1 } } }",

            "{ $lookup: { " +
                    "from: 'initiatives', " +
                    "let: { projectId: { $toObjectId: '$_id' } }, " +
                    "pipeline: [ " +
                    "{ $match: { $expr: { $eq: ['$_id', '$$projectId'] } } } " +
                    "], " +
                    "as: 'project' " +
                    "} }",

            "{ $unwind: '$project' }",

            "{ $project: { " +
                    "title: '$project.title', " +
                    "views: 1, " +
                    "_id: 0 " +
                    "} }",

            "{ $sort: { views: -1 } }",

            "{ $limit: 10 }"
    })
    List<TopProjectDto> getTopProjects();
}
